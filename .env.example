TELEGRAM_BOT_TOKEN=your_bot_token_here
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/velocity_bingo?retryWrites=true&w=majority

# Bot owner Telegram user ID (get from @userinfobot)
OWNER_ID=123456789

# Group/channel ID where bot logs are sent (optional)
# Get by adding the bot to the group and checking its ID
LOGGER_GROUP_ID=-1001234567890

# Support channel URL shown as inline button on turn panels (optional)
SUPPORT_CHANNEL=https://t.me/yourchannel
